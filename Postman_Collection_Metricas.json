{
  "info": {
    "name": "Droguería Bellavista - Métricas de Calidad",
    "description": "Collection para demostrar las métricas de calidad del proyecto",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://drogueria-bellavista-api.onrender.com/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "PROCESO 1: LOGIN",
      "item": [
        {
          "name": "Métrica 1.3 - Registro de Usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"metrica_test\",\n  \"email\": \"metrica@test.com\",\n  \"password\": \"Test123456\",\n  \"firstName\": \"Usuario\",\n  \"lastName\": \"Prueba\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Métrica 1.3 - Login Exitoso (Repetir 10 veces)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Guardar token automáticamente",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"token\", jsonData.token);",
                  "    console.log(\"Token guardado: \" + jsonData.token.substring(0, 20) + \"...\");",
                  "}",
                  "",
                  "// Verificar tiempo de respuesta",
                  "pm.test(\"Tiempo de respuesta < 2s\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "// Verificar status",
                  "pm.test(\"Status 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"metrica_test\",\n  \"password\": \"Test123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Métrica 1.3 - Login con Credenciales Inválidas",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"metrica_test\",\n  \"password\": \"PasswordIncorrecto\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "PROCESO 2: GESTIÓN DE PEDIDOS",
      "item": [
        {
          "name": "Métrica 2.1 - Crear Pedido (Repetir 10 veces)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verificar tiempo de respuesta",
                  "pm.test(\"Tiempo de respuesta ≤ 2s\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "    console.log(\"Tiempo: \" + pm.response.responseTime + \"ms\");",
                  "});",
                  "",
                  "// Verificar status",
                  "pm.test(\"Status 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 2\n    },\n    {\n      \"productId\": 2,\n      \"quantity\": 1\n    }\n  ],\n  \"notes\": \"Pedido de prueba para métrica 2.1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Métrica 2.2 - Error: Stock Insuficiente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verificar que el mensaje es claro",
                  "pm.test(\"Mensaje de error claro\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include(\"Stock insuficiente\");",
                  "    pm.expect(jsonData.message).to.include(\"Disponible\");",
                  "    pm.expect(jsonData.message).to.include(\"solicitado\");",
                  "});",
                  "",
                  "// Verificar status 400",
                  "pm.test(\"Status 400 Bad Request\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 99999\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Métrica 2.2 - Error: Producto Inexistente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verificar que el mensaje es claro",
                  "pm.test(\"Mensaje de error claro\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include(\"no encontrado\");",
                  "});",
                  "",
                  "// Verificar status 404",
                  "pm.test(\"Status 404 Not Found\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"items\": [\n    {\n      \"productId\": 99999,\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Métrica 2.2 - Error: Items Vacío",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verificar que el mensaje es claro",
                  "pm.test(\"Mensaje de error claro\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include(\"items\");",
                  "    pm.expect(jsonData.message).to.include(\"obligatorio\");",
                  "});",
                  "",
                  "// Verificar status 400",
                  "pm.test(\"Status 400 Bad Request\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"items\": []\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            }
          }
        }
      ]
    },
    {
      "name": "PROCESO 3: CONTROL DE INVENTARIO",
      "item": [
        {
          "name": "Métrica 3.3 - Listar Productos (Repetir 10 veces)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verificar tiempo de respuesta",
                  "pm.test(\"Tiempo de respuesta ≤ 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "    console.log(\"Tiempo: \" + pm.response.responseTime + \"ms\");",
                  "});",
                  "",
                  "// Verificar status",
                  "pm.test(\"Status 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Métrica 3.3 - Buscar por Nombre",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Tiempo de respuesta ≤ 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products?name=Acetaminofen",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                {
                  "key": "name",
                  "value": "Acetaminofen"
                }
              ]
            }
          }
        },
        {
          "name": "Métrica 3.3 - Buscar por Código",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Tiempo de respuesta ≤ 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products/code/MED001",
              "host": ["{{base_url}}"],
              "path": ["products", "code", "MED001"]
            }
          }
        }
      ]
    },
    {
      "name": "PROCESO 4: GESTIÓN DE VENTAS",
      "item": [
        {
          "name": "Métrica 4.2 - Confirmar Orden (Repetir 10 veces)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verificar tiempo de respuesta",
                  "pm.test(\"Tiempo de respuesta ≤ 2s\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "    console.log(\"Tiempo: \" + pm.response.responseTime + \"ms\");",
                  "});",
                  "",
                  "// Verificar status",
                  "pm.test(\"Status 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Verificar que el estado cambió",
                  "pm.test(\"Estado cambió a COMPLETED\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql(\"COMPLETED\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/orders/1/confirm",
              "host": ["{{base_url}}"],
              "path": ["orders", "1", "confirm"]
            }
          }
        },
        {
          "name": "Métrica 4.3 - Control de Acceso (USER - debe fallar)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verificar que se rechaza correctamente",
                  "pm.test(\"Status 403 Forbidden\", function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/orders/1/confirm",
              "host": ["{{base_url}}"],
              "path": ["orders", "1", "confirm"]
            }
          }
        }
      ]
    }
  ]
}
